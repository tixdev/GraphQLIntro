{
  "name": "graphql-intro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node infra/dev-server/dev.js",
    "dev:tunnel": "cloudflared tunnel run --token eyJhIjoiMGM0ZTY5YWEzZTIwNTFiZTQ3MDVkYzMyOTU5MWQzMjYiLCJ0IjoiOTY1NTdmNGUtOTg2My00ZjEzLTgxODEtZWM0YTkzNGIyOGRhIiwicyI6IlpEUXlOell4TVRndFpXSTRNeTAwTnpjMUxXRmlZV1l0WmpFeVpUQXpaakprWWpFeCJ9",
    "dev:public": "PUBLIC_URL=$PUBLIC_URL node infra/dev-server/dev.js",
    "dev:api": "concurrently \"dotnet run --project services/apis/Person.API/Person.API.csproj\" \"dotnet run --project services/apis/Relationship.API/Relationship.API.csproj\" \"dotnet run --project services/apis/Asset.API/Asset.API.csproj\" \"dotnet run --project services/apis/Balance.API/Balance.API.csproj\"",
    "compose": "APOLLO_ELV2_LICENSE=accept ~/.rover/bin/rover supergraph compose --config services/gateway/supergraph-config.yaml > services/gateway/supergraph.graphql",
    "dev:router": "APOLLO_ROUTER_CONFIG_PATH=services/gateway/router-config.yaml ./services/gateway/router --config services/gateway/router-config.yaml --supergraph services/gateway/supergraph.graphql --hot-reload",
    "dev:supergraph": "concurrently \"npm run dev:api\" \"sleep 5 && npm run dev:router\"",
    "dev:supergraphonly": "npm run dev:router"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^6.1.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "codejar": "^4.3.0",
    "graphql": "^16.12.0",
    "prismjs": "^1.30.0",
    "qrcode": "^1.5.4",
    "ws": "^8.18.0"
  }
}