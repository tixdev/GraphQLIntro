{
  "name": "graphql-intro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server/dev.js",
    "dev:tunnel": "cloudflared tunnel run --token eyJhIjoiMGM0ZTY5YWEzZTIwNTFiZTQ3MDVkYzMyOTU5MWQzMjYiLCJ0IjoiOTY1NTdmNGUtOTg2My00ZjEzLTgxODEtZWM0YTkzNGIyOGRhIiwicyI6IlpEUXlOell4TVRndFpXSTRNeTAwTnpjMUxXRmlZV1l0WmpFeVpUQXpaakprWWpFeCJ9",
    "dev:public": "PUBLIC_URL=$PUBLIC_URL node server/dev.js",
    "dev:api": "concurrently \"dotnet run --project demo-server/Person.API/Person.API.csproj\" \"dotnet run --project demo-server/Relationship.API/Relationship.API.csproj\" \"dotnet run --project demo-server/Asset.API/Asset.API.csproj\" \"dotnet run --project demo-server/Balance.API/Balance.API.csproj\"",
    "compose": "APOLLO_ELV2_LICENSE=accept ~/.rover/bin/rover supergraph compose --config apollo-gateway/supergraph-config.yaml > apollo-gateway/supergraph.graphql",
    "dev:router": "node apollo-gateway/index.mjs",
    "dev:supergraph": "concurrently \"npm run dev:api\" \"sleep 8 && npm run dev:router\"",
    "dev:supergraphobly": "npm run dev:router"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^6.1.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@apollo/gateway": "^2.13.1",
    "@apollo/server": "^5.4.0",
    "codejar": "^4.3.0",
    "graphql": "^16.12.0",
    "prismjs": "^1.30.0",
    "qrcode": "^1.5.4",
    "ws": "^8.18.0"
  }
}